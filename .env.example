# Copy to .env and fill in as needed. With NO provider keys, the stack runs
# the mock provider only (use the notebook scenarios / `harness.cli demo`).

# ── Provider API keys (optional; each lights up one chain link) ──
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# XAI_API_KEY=
# ── Dispatch / storage (set by docker-compose for in-cluster DNS) ──
# PG_MAIN_DSN=postgresql://harness:harness@localhost:5432/harness
# ARTIFACTS_ROOT=./_artifacts

# ── Decision sink: 'file' (default, ADR-0015 layout) or 'postgres' ──
# DECISION_SINK=file
# DECISION_PG_DSN=postgresql://harness:harness@localhost:5432/harness

# ── S3 / MinIO (for the S3 connector) ──
# S3_ENDPOINT_URL=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin

# ── MCP policy_service over Streamable HTTP (else falls back to stdio) ──
# MCP_POLICY_URL=http://localhost:9100/mcp
